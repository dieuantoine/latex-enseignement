% --------------------------------------------------
% Titre du document
% --------------------------------------------------

\newcommand{\creertitre}[1]{%
    \vspace*{-1em}
    \begin{center}
        {%
            \setlength{\fboxsep}{15pt}
            \fbox{%
                \parbox{0.9\linewidth}{%
                    \centering
                    \Large \textbf{#1}
                }%
            }%
        }%
    \end{center}
    \vspace{0.2em}
}